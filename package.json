{
  "name": "@aegisjsproject/toast-message",
  "version": "1.0.2",
  "description": "A modern, dependency-free <toast-message> web component powered by the Popover API",
  "keywords": [
    "toast",
    "toast-message",
    "notification",
    "web-component",
    "custom-element",
    "popover",
    "popover-api",
    "alert",
    "snackbar"
  ],
  "type": "module",
  "main": "./toast-message.cjs",
  "module": "./toast-message.js",
  "unpkg": "./toast-message.min.js",
  "exports": {
    ".": {
      "import": "./toast-message.js",
      "require": "./toast-message.cjs"
    },
    "./*.js": {
      "import": "./*.js",
      "require": "./*.cjs"
    },
    "./*.mjs": {
      "import": "./*.js",
      "require": "./*.cjs"
    },
    "./*.cjs": {
      "import": "./*.js",
      "require": "./*.cjs"
    },
    "./*": {
      "import": "./*.js",
      "require": "./*.cjs"
    }
  },
  "engines": {
    "node": ">=24.10.0"
  },
  "private": false,
  "scripts": {
    "test": "npm run lint:js && npm run run:tests",
    "start": "http-server -c ./http.config.js",
    "preversion": "npm test && npm run build --if-present",
    "prepare": "npm test && npm run build --if-present",
    "lint:js": "eslint .",
    "fix:js": "eslint . --fix",
    "build": "npm run build:js",
    "run:tests": "node --test",
    "clean": "rm -f ./*.cjs",
    "build:js": "npm run clean && rollup -c rollup.config.js",
    "create:lock": "npm i --package-lock-only --ignore-scripts --no-audit --no-fund",
    "version:bump": "npm run version:bump:patch",
    "version:bump:patch": "npm version --no-git-tag-version patch && npm run create:lock",
    "version:bump:minor": "npm version --no-git-tag-version minor && npm run create:lock",
    "version:bump:major": "npm version --no-git-tag-version major && npm run create:lock"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AegisJSProject/toast-message.git"
  },
  "author": "Chris Zuber <admin@kernvalley.us>",
  "license": "MIT",
  "funding": [
    {
      "type": "librepay",
      "url": "https://liberapay.com/shgysk8zer0"
    },
    {
      "type": "github",
      "url": "https://github.com/sponsors/shgysk8zer0"
    }
  ],
  "bugs": {
    "url": "https://github.com/AegisJSProject/toast-message/issues"
  },
  "homepage": "https://github.com/AegisJSProject/toast-message#readme",
  "devDependencies": {
    "@aegisjsproject/dev-server": "^1.0.6",
    "@aegisjsproject/http-utils": "^1.0.4",
    "@rollup/plugin-terser": "^1.0.0",
    "@shgysk8zer0/eslint-config": "^1.0.9",
    "@shgysk8zer0/http-server": "^1.1.2",
    "@shgysk8zer0/importmap": "^1.9.16",
    "eslint": "^10.3.0",
    "rollup": "^4.60.3"
  }
}
